      "targetState": "end"
    },
    {
      "id": "state4",
      "name": "状态4-肌松药+仅捏球囊通气",
      "monitor": {
        "NIBP": {
          "systolic": 98,
          "diastolic": 56
        },
        "SPO2": 100,
        "HR": 86,
        "RR": 20,
        "temperature": 36.8
      },
      "description": "使用肌松药后仅手捏球囊通气，生命体征恢复正常",
