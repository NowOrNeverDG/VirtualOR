            "monitorChange": {}
          },
          "nextStep": "生命体征无改变，状态继续向状态2发展"
        },
        {
          "id": "antagonistDrugs",
          "name": "使用氟马西尼/纳洛酮（拮抗药）",
          "effect": {
            "monitorChange": {}
          },
          "nextStep": "生命体征无改变，状态继续向状态2发展"
        }
      ]
    },
    {
      "id": "state2",
      "name": "状态2-未插管最恶化状态",
