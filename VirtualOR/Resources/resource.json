    {
      "id": "state3",
      "name": "状态3-肌松后无有效通气",
      "monitor": {
        "NIBP": {
          "systolic": 105,
          "diastolic": 61
        },
        "SPO2": 50,
        "HR": 60,
        "RR": 0,
        "temperature": 36.8
      },
      "description": "使用肌松药后未进行插管或捏球囊，呼吸停止",
